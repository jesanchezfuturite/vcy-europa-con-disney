---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ExperienceGrid from '../components/ExperienceGrid.astro';
import InclusionList from '../components/InclusionList.astro';
import MomentsGrid from '../components/MomentsGrid.astro';
import ItineraryCarousel from '../components/ItineraryCarousel.astro';
import FeaturesGrid from '../components/FeaturesGrid.astro';
import Upgrades from '../components/Upgrades.astro';
import ClosingBanner from '../components/ClosingBanner.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Europa con Disney París 2026 | ¡El viaje de tus sueños existe!">
