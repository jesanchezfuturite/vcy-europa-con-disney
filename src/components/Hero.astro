---
---
<section class="relative h-screen min-h-[700px] flex items-center justify-center overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/hero.jpg" 
      alt="Europa con Disney 2026" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 container mx-auto px-4 text-center text-white">
    <span class="inline-block px-4 py-1 bg-amber-400 text-black font-bold text-sm tracking-widest uppercase mb-6 rounded-full">
      EUROPA CON DISNEY 2026
    </span>
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6 max-w-5xl mx-auto">
      ¡EL VIAJE DE TUS SUEÑOS EXISTE! <br/>
      <span class="text-amber-400">CONOCE EUROPA Y DISNEYLAND PARÍS EN FAMILIA</span>
    </h1>
    <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-8 mb-8 text-lg md:text-xl font-medium">
      <p>15 días / 13 noches</p>
      <span class="hidden md:block w-2 h-2 bg-amber-400 rounded-full"></span>
      <p>Salida: 27 de septiembre de 2026</p>
    </div>
    
    <div class="mb-10">
      <p class="text-3xl md:text-5xl font-bold text-amber-400 mb-2">$67,900 MXN <span class="text-lg md:text-xl text-white font-normal">por persona</span></p>
      <p class="text-xl md:text-2xl font-semibold italic text-gray-200">Aparta hoy con solo $5,500 MXN</p>
    </div>

    <a 
      href="#formulario-contacto" 
      class="inline-block bg-amber-400 hover:bg-amber-500 text-black font-bold py-4 px-8 md:px-12 rounded-full text-lg md:text-xl transition-all duration-300 transform hover:scale-105 shadow-xl"
    >
      Quiero conocer Europa y vivir Disney París en familia
    </a>
    <p class="mt-6 text-gray-300 text-sm md:text-base">
      Cupo limitado · Atención antes y durante el viaje
    </p>
  </div>
</section>
