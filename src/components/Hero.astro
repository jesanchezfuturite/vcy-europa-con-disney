---
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden py-20 lg:py-0">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/hero.jpg" 
      alt="Europa con Disney 2026" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 container mx-auto px-4">
    <div class="flex flex-col items-center justify-center gap-8">
      <!-- Logo -->
      <div class="flex justify-center">
        <img 
          src="/images/vcy-logo-bco.png" 
          alt="Viaja Como Yo Logo" 
          class="w-32 md:w-40 h-auto drop-shadow-[0_0_15px_rgba(255,255,255,0.8)]"
        />
      </div>

      <!-- Text Content -->
      <div class="w-full max-w-5xl text-center text-white">
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Europa + Disney París 2026 <br/>
          <span class="text-amber-400 text-xl md:text-3xl lg:text-4xl">El viaje familiar que siempre soñaron</span>
        </h1>
        <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-8 mb-8 text-lg md:text-xl font-medium">
          <p>15 días / 13 noches</p>
          <span class="hidden md:block w-2 h-2 bg-amber-400 rounded-full"></span>
          <p>Salida: 27 de septiembre de 2026</p>
        </div>
        
        <div class="mb-10">
          <p class="text-3xl md:text-5xl font-bold text-amber-400 mb-2">$67,900 MXN <span class="text-lg md:text-xl text-white font-normal">por persona</span></p>
          <p class="text-xl md:text-2xl font-semibold italic text-gray-200">Aparta hoy con solo $5,500 MXN</p>
        </div>

        <a 
          href="#formulario-contacto" 
          class="inline-block bg-amber-400 hover:bg-amber-500 text-black font-bold py-4 px-8 md:px-12 rounded-full text-lg md:text-xl transition-all duration-300 transform hover:scale-105 shadow-xl"
        >
          Reservar mi lugar
        </a>
        <p class="mt-6 text-gray-300 text-sm md:text-base">
          Cupo limitado · Atención antes y durante el viaje
        </p>
      </div>
    </div>
  </div>
</section>
