---
const moments = [
  {
    title: "Su primera góndola en los canales de Venecia",
    desc: "Navegar juntos por una de las ciudades más mágicas del mundo, sorprendiendo a los niños con un paisaje sacado de un cuento.",
    image: "/images/venecia.webp"
  },
  {
    title: "Postales frente al Big Ben y la Torre Eiffel",
    desc: "Caminar por las avenidas más icónicas de Londres y París, tomándose la foto familiar que se quedará en la sala de la casa para siempre.",
    image: "/images/bigben.webp"
  },
  {
    title: "La noche mágica en Disneyland París",
    desc: "Vivir juntos el espectacular desfile nocturno Disney Stars on Parade y ver los ojos de tus hijos brillar con la música, los personajes y el show final.",
    image: "/images/disney.jpg"
  }
];
---
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-5xl font-bold text-center mb-16 uppercase tracking-tight">LOS MOMENTOS QUE RECORDARÁS PARA SIEMPRE</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {moments.map(moment => (
        <div class="bg-gray-50 rounded-[2.5rem] border border-gray-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-2 group overflow-hidden">
          <div class="h-64 overflow-hidden">
            <img src={moment.image} alt={moment.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
          </div>
          <div class="p-10">
            <h3 class="text-2xl font-bold text-gray-900 mb-4 leading-snug">
              {moment.title}
            </h3>
            <p class="text-gray-600 leading-relaxed">
              {moment.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
