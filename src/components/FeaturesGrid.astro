---
const features = [
  {
    title: "Coordinador de grupo a bordo",
    desc: "Un experto de nuestro equipo te acompaña durante todo el circuito europeo para guiarte en cada frontera y resolver cualquier imprevisto.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>`
  },
  {
    title: "Logística multinación resuelta",
    desc: "Olvídate de descifrar estaciones o comprar boletos; los trayectos en autocar de lujo entre los países y el cuzco en Ferry ya están coordinados.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>`
  },
  {
    title: "Guías locales oficiales",
    desc: "Recorre los monumentos históricos de las principales capitales con explicaciones profesionales y 100% en español.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>`
  },
  {
    title: "Asistencia médica internacional",
    desc: "Viajas completamente protegido gracias al seguro de viajero con cobertura internacional ya incluido en el precio de tu paquete.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>`
  }
];
---
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-5xl font-bold text-center mb-16 uppercase tracking-tight">EL RESPALDO QUE NECESITAS AL VIAJAR LEJOS</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {features.map(feature => (
        <div class="p-8 rounded-3xl bg-gray-50 border border-gray-100 hover:border-amber-400 transition-colors duration-300">
          <div class="w-12 h-12 bg-amber-400 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={feature.icon}></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 leading-snug">
            {feature.title}
          </h3>
          <p class="text-gray-600 leading-relaxed text-sm">
            {feature.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
